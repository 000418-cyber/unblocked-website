<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FreePlay Games</title>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        text-align: center;
    }

    header {
        padding: 20px;
        font-size: 2em;
        font-weight: bold;
        background: rgba(0,0,0,0.3);
    }

    .games-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        padding: 20px;
    }

    .game-card {
        background: rgba(255,255,255,0.1);
        padding: 15px;
        border-radius: 15px;
        transition: 0.3s;
    }

    .game-card:hover {
        transform: scale(1.05);
        background: rgba(255,255,255,0.2);
    }

    button {
        padding: 10px 15px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-weight: bold;
        background: #ffcc00;
        margin-top: 10px;
    }

    button:hover {
        background: #ffaa00;
    }

    #gameFrame {
        width: 90%;
        height: 500px;
        border: none;
        margin-top: 20px;
        border-radius: 15px;
        display: none;
    }

    footer {
        padding: 15px;
        background: rgba(0,0,0,0.3);
        margin-top: 20px;
    }
</style>
</head>

<body>

<header>🎮 FreePlay Games</header>

<div class="games-container">
    
    <div class="game-card">
        <h2>Tetris</h2>
        <p>Classic block stacking fun!</p>
        <button onclick="loadGame('https://tetris.com/play-tetris')">Play</button>
    </div>

    <div class="game-card">
        <h2>Snake</h2>
        <p>Eat and grow longer!</p>
        <button onclick="loadGame('https://playsnake.org/')">Play</button>
    </div>

    <div class="game-card">
        <h2>Pacman</h2>
        <p>Retro arcade action!</p>
        <button onclick="loadGame('https://www.google.com/logos/2010/pacman10-i.html')">Play</button>
    </div>

</div>

<iframe id="gameFrame"></iframe>

<footer>
    © 2026 FreePlay Games | All games belong to their owners
</footer>

<script>
function loadGame(url) {
    const frame = document.getElementById("gameFrame");
    frame.style.display = "block";
    frame.src = url;
    window.scrollTo({
        top: frame.offsetTop,
        behavior: "smooth"
    });
}
</script>

</body>
</html>
